APP_NAME=云上田园 - Cloud Farm
DATABASE_URL=sqlite+aiosqlite:///./cloud_farm.db

# AI Provider 配置: glm | 空(使用本地模板)
AI_PROVIDER=glm

# 智谱 GLM 配置 (https://open.bigmodel.cn/)
# 请在此填写你的智谱API Key
GLM_API_KEY=your-api-key-here
GLM_MODEL=glm-4.5-air

WEATHER_API_BASE=https://api.open-meteo.com/v1
DEFAULT_LATITUDE=30.50
DEFAULT_LONGITUDE=114.34
SENSOR_UPDATE_INTERVAL=5
